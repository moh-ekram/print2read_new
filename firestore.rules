rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        getUserRole() == 'admin' || 
        request.auth.token.email == 'admin@readtoprint.com'
      );
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Posts Collection
    match /posts/{postId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && (getUserRole() == 'writer' || isAdmin());
      allow update: if isAuthenticated() && (request.resource.data.authorId == request.auth.uid || isAdmin() || request.resource.data.viewCount == resource.data.viewCount + 1 || request.resource.data.addToPrintCount == resource.data.addToPrintCount + 1);
      allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // 3. Transactions Collection
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // 4. Withdraw Requests Collection
    match /withdrawRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin(); // Only admin can approve or reject
      allow delete: if isAdmin();
    }

    // 5. Global History Collection
    match /globalHistory/{historyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // 6. Test/Connection Validation Collection
    match /test/connection {
      allow read, write: if true;
    }
  }
}
