rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function userDocExists(userId) {
      return exists(/databases/$(database)/documents/users/$(userId));
    }
    
    function getUserRole(userId) {
      return userDocExists(userId) ? get(/databases/$(database)/documents/users/$(userId)).data.role : 'reader';
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        ('email' in request.auth.token && request.auth.token.email == 'admin@readtoprint.com') ||
        ('email' in request.auth.token && request.auth.token.email == 'mohammad.001ekram@gmail.com') ||
        ('email' in request.auth.token && request.auth.token.email == 'dusahityaparishad@gmail.com') ||
        getUserRole(request.auth.uid) == 'admin'
      );
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isAuthenticated() && (
        isAdmin() ||
        // Owner can update everything EXCEPT their role (unless their role doesn't change or they have an admin email)
        (isOwner(userId) && (
          !('role' in request.resource.data) || 
          !('role' in resource.data) || 
          request.resource.data.role == resource.data.role ||
          // Admin emails can elevate themselves to admin role
          ('email' in request.auth.token && request.auth.token.email == 'admin@readtoprint.com') ||
          ('email' in request.auth.token && request.auth.token.email == 'mohammad.001ekram@gmail.com') ||
          ('email' in request.auth.token && request.auth.token.email == 'dusahityaparishad@gmail.com')
        )) ||
        // Transactional updates to another user (e.g., paying an author during basket actions)
        (!isOwner(userId) && (
          // Ensure they don't change core profile info like role, displayName, or email
          (!('role' in request.resource.data) || !('role' in resource.data) || request.resource.data.role == resource.data.role) &&
          (!('displayName' in request.resource.data) || !('displayName' in resource.data) || request.resource.data.displayName == resource.data.displayName) &&
          (!('email' in request.resource.data) || !('email' in resource.data) || request.resource.data.email == resource.data.email) &&
          // Ensure coins and balance are not decreased
          (!('coins' in request.resource.data) || !('coins' in resource.data) || request.resource.data.coins >= resource.data.coins) &&
          (!('currentBalance' in request.resource.data) || !('currentBalance' in resource.data) || request.resource.data.currentBalance >= resource.data.currentBalance)
        ))
      );
      allow delete: if isAdmin();
    }

    // 2. Posts Collection
    match /posts/{postId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && (getUserRole(request.auth.uid) == 'writer' || isAdmin());
      allow update: if isAuthenticated() && (
        request.resource.data.authorId == request.auth.uid || 
        isAdmin() || 
        // Allow view count or print count adjustments safely
        (!('viewCount' in request.resource.data) || !('viewCount' in resource.data) || request.resource.data.viewCount >= resource.data.viewCount) ||
        (!('addToPrintCount' in request.resource.data) || !('addToPrintCount' in resource.data) || request.resource.data.addToPrintCount >= resource.data.addToPrintCount - 1)
      );
      allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // 3. Transactions Collection
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // 4. Withdraw Requests Collection
    match /withdrawRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin(); // Only admin can approve or reject
      allow delete: if isAdmin();
    }

    // 5. Global History Collection
    match /globalHistory/{historyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // 6. Test/Connection Validation Collection
    match /test/connection {
      allow read, write: if true;
    }

    // 7. Writer Applications Collection
    match /writerApplications/{appId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 8. Orders Collection
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 9. Settlements Collection
    match /settlements/{settlementId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
